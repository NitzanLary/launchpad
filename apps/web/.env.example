# Database
DATABASE_URL="postgresql://user:password@localhost:5432/launchpad?schema=public"

# Auth.js
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# GitHub OAuth (Auth.js sign-in + API access)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# App URL (used for webhook registration)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Encryption (32-byte hex = 64 characters; generate with: openssl rand -hex 32)
ENCRYPTION_KEY=""

# Inngest
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# Vercel Integration OAuth (Phase 1)
# INTEGRATION_VERCEL_CLIENT_ID doubles as the integration id passed to
# vercel.com/new/clone?integration-ids=... during project creation, so the
# integration is installed on the new project during the clone flow —
# this is what lets our vci token manage env vars and deployments afterwards.
INTEGRATION_VERCEL_CLIENT_ID=""
INTEGRATION_VERCEL_CLIENT_SECRET=""
INTEGRATION_VERCEL_SLUG=""

# Supabase OAuth (Phase 1)
SUPABASE_CLIENT_ID=""
SUPABASE_CLIENT_SECRET=""
