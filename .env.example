# LaunchPad Platform — Environment Variables
# Copy to .env.local and fill in values

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/launchpad?schema=public"

# ─── Auth.js ──────────────────────────────────────────────────────────────────
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# ─── GitHub OAuth ─────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ─── GitHub Webhooks ──────────────────────────────────────────────────────────
GITHUB_WEBHOOK_SECRET=""

# ─── Encryption ───────────────────────────────────────────────────────────────
# 32-byte hex string for AES-256-GCM: openssl rand -hex 32
ENCRYPTION_KEY=""

# ─── Inngest ──────────────────────────────────────────────────────────────────
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# ─── Vercel OAuth (Phase 1) ──────────────────────────────────────────────────
# INTEGRATION_VERCEL_CLIENT_ID=""
# INTEGRATION_VERCEL_CLIENT_SECRET=""

# ─── Supabase OAuth (Phase 1) ────────────────────────────────────────────────
# SUPABASE_CLIENT_ID=""
# SUPABASE_CLIENT_SECRET=""
